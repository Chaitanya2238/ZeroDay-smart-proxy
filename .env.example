# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control!

# Google Gemini API Key (get from https://aistudio.google.com/)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (for backward compatibility)
# OPENAI_API_KEY=your_openai_key_here

# Phase 2 Analyzer Settings
ANALYZER_CHECK_INTERVAL=5
ANALYZER_LOG_FILE=proxy.log
ANALYZER_ALERTS_FILE=phase2/alerts.json
ANALYZER_STATS_FILE=phase2/statistics.json
